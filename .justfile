####################################################################################################

_default:
  @just --choose

####################################################################################################

@show:
  bat .justfile --language make

####################################################################################################

@edit:
  micro .justfile

####################################################################################################
# jobs
####################################################################################################

# build exec
@build:
  @echo "\n\033[1;33mBuilding\033[0;37m...\n=================================================="
  cargo clean; cargo build --release

####################################################################################################

# install locally
install:
  @echo "\n\033[1;33mInstalling\033[0;37m...\n=================================================="
  cargo install --path .
  coyote completion zsh > $HOME/.config/zsh_completion/_coyote

####################################################################################################

# watch
@watch:
  cargo watch --clear --why --exec check

####################################################################################################
