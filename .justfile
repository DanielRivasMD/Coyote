####################################################################################################

_default:
  @just --choose

####################################################################################################

@abort:

####################################################################################################

@list:
  just --list

####################################################################################################

# print justfile
[group('just')]
@show:
  bat .justfile --language make

####################################################################################################

# edit justfile
[group('just')]
@edit:
  micro .justfile

####################################################################################################

# compile roadmap action items
[group('dev')]
@todor:
  if [ "$(uname)" = "Darwin" ]; then \
    sed -i '' '/^==================================================$/,/^==================================================$/d' ROADMAP.txt; \
  else \
    sed -i '/^==================================================[[:space:]]*$/,/^==================================================[[:space:]]*$/d' ROADMAP.txt; \
  fi
  { printf '==================================================\n'; todor -s; printf '==================================================\n'; } >> ROADMAP.txt

####################################################################################################
# jobs
####################################################################################################

# build
[group('dev')]
@debug:
  @echo "\n\033[1;33mBuilding\033[0;37m...\n=================================================="
  cargo build

####################################################################################################

# build release
[group('dev')]
@build:
  @echo "\n\033[1;33mBuilding\033[0;37m...\n=================================================="
  cargo clean; cargo build --release

####################################################################################################

# watch
[group('dev')]
@watch:
  cargo watch --clear --why --exec check

####################################################################################################

# print help
[group('dev')]
@help:
  @echo "\n\033[1;33mPrinting\033[0;37m...\n=================================================="
  cargo run -- --help

####################################################################################################

# diagnose clippy
[group('dev')]
@clippy:
  cargo watch --clear --shell 'cargo clippy'

####################################################################################################
